{
  "sequence_name": "reference_heightfield_intrusion_v001",
  "description": "Reference sequence for physically inspectable granular intrusion with density, blade, and MuJoCo-Newton views.",
  "output_root": "outputs/experiments",
  "workspace": {
    "scan_depth": 2,
    "environment_hint": "Use the active Python/venv, or run ./install.sh --locked before this pipeline."
  },
  "stages": {
    "density_render": {
      "enabled": true,
      "device": "cuda:0",
      "frames": 60,
      "substeps": 34,
      "quick_frames": 6,
      "quick_substeps": 4
    },
    "blade_demo": {
      "enabled": true,
      "config": "configs/sand3d_blade_demo.json",
      "quick_device": "cpu",
      "quick_frames": 6,
      "quick_substeps_per_frame": 4,
      "overrides": {
        "display_force_scale": 0.0012,
        "mpm": {
          "young": 2200.0,
          "poisson": 0.24,
          "dp_alpha": 0.42,
          "gravity": -1.35,
          "tool_mu": 0.44,
          "damping": 0.998
        }
      }
    },
    "newton_bridge": {
      "enabled": true,
      "config": "configs/newton_bridge_heightfield.json",
      "quick_frames": 4,
      "quick_steps_per_frame": 1,
      "quick_voxel_size": 0.06,
      "quick_particles_per_cell": 1.2,
      "overrides": {
        "sand_render_mode": "heightfield",
        "render_blur": 2.4,
        "alpha_cutoff": 0.06,
        "alpha_gain": 0.48,
        "sand_density": 1550.0,
        "sand_friction": 0.74,
        "sand_young_modulus": 1000000.0,
        "sand_poisson": 0.28,
        "sand_yield_pressure": 1000000.0,
        "sand_damping": 0.02,
        "sand_jitter_scale": 1.8
      }
    }
  },
  "metrics": {
    "train_fraction": 0.7,
    "target": "force_norm",
    "baseline": "previous_force_norm"
  },
  "dataset": {
    "enabled": true,
    "sample_rate_hz": 50.0,
    "bridge_frame_rate_hz": 30.0,
    "window_length": 32,
    "stride": 8,
    "quick_window_length": 1,
    "quick_stride": 1,
    "normalization": "zscore",
    "train_fraction": 0.7,
    "validation_fraction": 0.15,
    "targets": {
      "phi_deg": 34.0,
      "cohesion_kpa": 0.05
    }
  },
  "learning": {
    "enabled": true,
    "device": "auto",
    "seed": 7,
    "batch_size": 32,
    "quick_batch_size": 4,
    "representation_epochs": 6,
    "quick_representation_epochs": 1,
    "mdn_epochs": 12,
    "quick_mdn_epochs": 1,
    "representation_lr": 0.001,
    "mdn_lr": 0.0008,
    "latent_dim": 64,
    "conv_channels": 64,
    "transformer_layers": 2,
    "attention_heads": 4,
    "dropout": 0.05,
    "num_mixtures": 3,
    "temperature": 0.12,
    "augmentation_noise_std": 0.015,
    "timing_repeats": 10
  }
}
